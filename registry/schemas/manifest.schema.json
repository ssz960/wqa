{
  "$id": "platform-registry-manifest.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "coverage_status": {
      "enum": [
        "COMPLETE",
        "PARTIAL"
      ]
    },
    "files": {
      "type": "array"
    },
    "generated_at": {
      "format": "date-time",
      "type": "string"
    },
    "snapshot_id": {
      "type": "string"
    },
    "source_commit": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    }
  },
  "required": [
    "snapshot_id",
    "generated_at",
    "source_commit",
    "files",
    "coverage_status"
  ],
  "type": "object"
}
